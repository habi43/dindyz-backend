# ─────────────────────────────────────────
#  DINDYZ DATA — Environment Variables
#  Copy this file to .env and fill in values
# ─────────────────────────────────────────

# SERVER
PORT=5000
NODE_ENV=development

# JWT SECRET (change this to a long random string!)
JWT_SECRET=dindyz_super_secret_change_this_in_production_2026

# ── FIREBASE ──────────────────────────────
# Get these from Firebase Console > Project Settings > Service Accounts
FIREBASE_PROJECT_ID=dindyz-data
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@dindyz-data.iam.gserviceaccount.com

# ── VTPASS API (VTU Provider) ─────────────
# Sign up at vtpass.com, get keys from Settings > API
VTPASS_BASE_URL=https://sandbox.vtpass.com/api
VTPASS_API_KEY=your_vtpass_api_key_here
VTPASS_SECRET_KEY=your_vtpass_secret_key_here
VTPASS_PUBLIC_KEY=your_vtpass_public_key_here

# ── PAYSTACK (Payment Gateway) ────────────
# Sign up at paystack.com, get keys from Settings > API
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key
PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public_key

# ── TERMII (SMS for OTP) ─────────────────
# Sign up at termii.com, get API key from dashboard
TERMII_API_KEY=your_termii_api_key
TERMII_SENDER_ID=Dindyz

# ── EMAIL (Nodemailer) ────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=admin@dindyzdata.com
EMAIL_PASS=your_gmail_app_password

# ── ADMIN ─────────────────────────────────
ADMIN_EMAIL=admin@dindyzdata.com
ADMIN_PHONE=08012345678

# ── LOW BALANCE ALERT ─────────────────────
VTPASS_LOW_BALANCE_THRESHOLD=20000
